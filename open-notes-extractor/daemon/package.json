{
  "name": "meki-sync-daemon",
  "version": "1.0.0",
  "description": "MekiSync — Apple/Samsung Notes 상시 가동 동기화 데몬 (Mac 메뉴바 / Windows 트레이)",
  "main": "index.js",
  "bin": {
    "mekisync": "index.js"
  },
  "scripts": {
    "start": "node index.js",
    "setup": "node index.js setup",
    "sync": "node index.js sync-now",
    "install-daemon": "node index.js install",
    "uninstall-daemon": "node index.js uninstall",
    "build-mac": "pkg index.js --targets node18-macos-arm64,node18-macos-x64 --output dist/mekisync-mac",
    "build-win": "pkg index.js --targets node18-win-x64 --output dist/mekisync-win.exe"
  },
  "optionalDependencies": {
    "menubar": "^9.0.1"
  },
  "devDependencies": {
    "pkg": "^5.8.1"
  },
  "engines": { "node": ">=18" },
  "license": "MIT"
}
